// PX4 + NuttX boot script for Renode.
//
// The fixture (`Px4RenodeSitl::boot`) injects two variables before
// running this file via Renode's `-e` flag:
//
//   $slave  — host-side pty path Renode attaches USART2 to. The
//             fixture opens the pty master end on the other side
//             and drives the pxh shell through it.
//   $bin    — absolute path to the px4_renode_h743 firmware ELF.
//             Set from the `PX4_RENODE_FIRMWARE` env var.
//
// `$bin` is required for full boot. Platform-probe runs (boot
// without firmware) skip the LoadELF + start lines via the
// alternate `.resc` snippet the fixture generates inline.

:name: PX4_RENODE_H743
:description: PX4 + NuttX firmware running on emulated STM32H743

mach create "PX4_RENODE_H743"
machine LoadPlatformDescription @platforms/px4_renode_h743.repl

# Wire USART2 to the pty the host fixture opened. The host master
# end will see anything the firmware writes and can write commands
# back into the firmware's NSH/pxh shell.
emulation CreateUartPtyTerminal "shellTerm" $slave true
connector Connect sysbus.usart2 shellTerm

# Load and run the firmware. The fixture has set `$bin` to an
# absolute path before this file is included.
macro reset
"""
    sysbus LoadELF $bin
"""
runMacro $reset

start
