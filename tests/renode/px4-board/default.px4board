# Phase-13 PX4 board manifest for the Renode-emulated STM32H743.
#
# Stripped to the bone: every CONFIG_DRIVERS_* and flight-stack
# CONFIG_MODULES_* is intentionally absent so the firmware has no
# code that touches a peripheral Renode doesn't model. We keep:
#
#   * the SoC architecture pin (cortex-m7)
#   * an empty ROMFS (no init.d-posix shell scripts)
#   * the systemcmds the e2e tests drive (uorb, ver, listener,
#     work_queue, perf, top, dmesg)
#   * the logger module (needed by uorb's broker for tracing)
#
# Everything else — sensors, actuators, EKF, mavlink, navigator,
# commander — stays out. Drivers we'd otherwise inherit from
# Pixhawk-shaped boards (CONFIG_DRIVERS_*) are not enabled, so the
# Kconfig select chains don't pull them in transitively.

CONFIG_BOARD_TOOLCHAIN="arm-none-eabi"
CONFIG_BOARD_ARCHITECTURE="cortex-m7"
CONFIG_BOARD_ROMFSROOT=""

# Shell-driven test surface.
CONFIG_SYSTEMCMDS_UORB=y
CONFIG_SYSTEMCMDS_VER=y
CONFIG_SYSTEMCMDS_TOPIC_LISTENER=y
CONFIG_SYSTEMCMDS_WORK_QUEUE=y
CONFIG_SYSTEMCMDS_PERF=y
CONFIG_SYSTEMCMDS_TOP=y
CONFIG_SYSTEMCMDS_DMESG=y
CONFIG_SYSTEMCMDS_PARAM=y
CONFIG_SYSTEMCMDS_REBOOT=y

# Logger keeps uorb's tracing infrastructure happy.
CONFIG_MODULES_LOGGER=y
